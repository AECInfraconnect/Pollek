{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollek.dev/schemas/ai-usage-summary.v1.schema.json",
  "title": "AiUsageSummaryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tenant_id",
    "bucket",
    "currency",
    "totals",
    "by_agent",
    "by_provider",
    "by_model",
    "series",
    "budgets"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "ai-usage-summary.v1" },
    "tenant_id": { "type": "string" },
    "from": { "type": "string", "format": "date-time" },
    "to": { "type": "string", "format": "date-time" },
    "bucket": { "type": "string" },
    "currency": { "type": "string" },
    "totals": { "$ref": "#/$defs/totals" },
    "by_agent": { "type": "array", "items": { "$ref": "#/$defs/breakdown" } },
    "by_provider": { "type": "array", "items": { "$ref": "#/$defs/breakdown" } },
    "by_model": { "type": "array", "items": { "$ref": "#/$defs/breakdown" } },
    "series": { "type": "array", "items": { "$ref": "#/$defs/series_point" } },
    "budgets": { "type": "array", "items": { "$ref": "#/$defs/budget_limit" } }
  },
  "$defs": {
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_count",
        "input_tokens",
        "output_tokens",
        "cached_input_tokens",
        "cache_write_input_tokens",
        "reasoning_output_tokens",
        "tool_tokens",
        "multimodal_tokens",
        "total_tokens",
        "total_cost"
      ],
      "properties": {
        "request_count": { "type": "integer" },
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "cached_input_tokens": { "type": "integer" },
        "cache_write_input_tokens": { "type": "integer" },
        "reasoning_output_tokens": { "type": "integer" },
        "tool_tokens": { "type": "integer" },
        "multimodal_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "total_cost": { "type": "number" }
      }
    },
    "budget_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window", "status"],
      "properties": {
        "window": { "type": "string" },
        "hard_cost_limit": { "type": "number" },
        "hard_token_limit": { "type": "integer" },
        "remaining_cost": { "type": "number" },
        "remaining_tokens": { "type": "integer" },
        "status": { "type": "string" }
      }
    },
    "breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "request_count", "total_tokens", "total_cost"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "agent_type": { "type": "string" },
        "request_count": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "total_cost": { "type": "number" },
        "budget": { "$ref": "#/$defs/budget_status" }
      }
    },
    "series_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket_start",
        "request_count",
        "input_tokens",
        "output_tokens",
        "cached_input_tokens",
        "reasoning_output_tokens",
        "total_tokens",
        "total_cost"
      ],
      "properties": {
        "bucket_start": { "type": "string", "format": "date-time" },
        "request_count": { "type": "integer" },
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "cached_input_tokens": { "type": "integer" },
        "reasoning_output_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "total_cost": { "type": "number" }
      }
    },
    "budget_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "budget_id",
        "tenant_id",
        "scope_type",
        "scope_id",
        "window",
        "currency",
        "action_on_soft",
        "action_on_hard",
        "enabled",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "ai-budget-limit.v1" },
        "budget_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "scope_type": { "type": "string" },
        "scope_id": { "type": "string" },
        "window": { "type": "string" },
        "currency": { "type": "string" },
        "soft_cost_limit": { "type": "number" },
        "hard_cost_limit": { "type": "number" },
        "soft_token_limit": { "type": "integer" },
        "hard_token_limit": { "type": "integer" },
        "action_on_soft": { "type": "string" },
        "action_on_hard": { "type": "string" },
        "enabled": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
