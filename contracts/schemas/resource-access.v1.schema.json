{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollek.dev/schemas/resource-access.v1.schema.json",
  "title": "ResourceAccessPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "agent_label",
    "scope",
    "kind",
    "target_redacted",
    "target_hash",
    "mode",
    "decision",
    "enforced_for_real",
    "observed_at"
  ],
  "properties": {
    "agent_id": { "type": "string" },
    "agent_label": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["local", "cloud"]
    },
    "kind": {
      "type": "string",
      "enum": ["file", "folder", "database_local", "os_syscall", "config", "process", "clipboard", "web", "email", "cloud_drive", "database_cloud", "data_source", "api", "saas"]
    },
    "target_redacted": { "type": "string" },
    "target_hash": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["read", "write", "execute", "delete", "connect", "invoke"]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "redact", "warn", "observed"]
    },
    "control_method": {
      "type": "string",
      "enum": [
        "mcp_stdio", "mcp_http",
        "linux_landlock", "linux_ebpf", "linux_seccomp",
        "windows_wfp_um", "windows_wfp_callout", "windows_etw",
        "macos_netext", "macos_endpoint_security"
      ]
    },
    "enforced_for_real": { "type": "boolean" },
    "bytes": { "type": "integer" },
    "count": { "type": "integer" },
    "classification": { "type": "string" },
    "details": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace_source": { "type": "string" },
        "capture_quality": { "type": "string" },
        "trace_granularity": { "type": "string" },
        "raw_content_stored": { "type": "boolean" },
        "source_path_hash": { "type": "string" },
        "source_path_redacted": { "type": "string" },
        "path_kind": { "type": "string" },
        "resource_name": { "type": "string" },
        "file_name": { "type": "string" },
        "file_extension": { "type": "string" },
        "folder_name": { "type": "string" },
        "folder_path": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "db_system": { "type": "string" },
        "db_namespace": { "type": "string" },
        "db_table": { "type": "string" },
        "db_collection": { "type": "string" },
        "db_operation": { "type": "string" },
        "query_summary": { "type": "string" },
        "query_fingerprint": { "type": "string" },
        "os_observer": { "type": "string" },
        "control_method": {
          "type": "string",
          "enum": [
            "mcp_stdio", "mcp_http",
            "linux_landlock", "linux_ebpf", "linux_seccomp",
            "windows_wfp_um", "windows_wfp_callout", "windows_etw",
            "macos_netext", "macos_endpoint_security"
          ]
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "observed_at": { "type": "string", "format": "date-time" }
  }
}
