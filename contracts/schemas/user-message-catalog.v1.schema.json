{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollek.dev/schemas/user-message-catalog.v1.schema.json",
  "title": "UserMessageCatalogV1",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "message_id",
      "reason_code",
      "severity",
      "title_en",
      "title_th",
      "body_en",
      "body_th",
      "action_hint"
    ],
    "properties": {
      "message_id": { "type": "string" },
      "reason_code": { "type": "string" },
      "severity": { "type": "string", "enum": ["info", "success", "warning", "danger"] },
      "title_en": { "type": "string" },
      "title_th": { "type": "string" },
      "body_en": { "type": "string" },
      "body_th": { "type": "string" },
      "action_hint": {
        "type": "string",
        "enum": ["none", "review", "approve", "install", "configure", "open_cloud"]
      },
      "docs_path": { "type": ["string", "null"] }
    }
  }
}
