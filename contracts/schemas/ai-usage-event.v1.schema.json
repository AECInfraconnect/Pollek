{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollen.dev/schemas/ai-usage-event.v1.schema.json",
  "title": "AiUsageEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_kind",
    "occurred_at",
    "received_at",
    "tenant_id",
    "trace_id",
    "span_id",
    "agent_type",
    "surface",
    "policy_ids",
    "tokens",
    "cost",
    "status",
    "provider_usage_raw",
    "metadata",
    "idempotency_key"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "ai-usage-event.v1" },
    "event_id": { "type": "string" },
    "event_kind": { "$ref": "#/$defs/ai_usage_event_kind" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "received_at": { "type": "string", "format": "date-time" },
    "tenant_id": { "type": "string" },
    "workspace_id": { "type": "string" },
    "device_id": { "type": "string" },
    "actor_id_hash": { "type": "string" },
    "actor_kind": { "type": "string" },
    "trace_id": { "type": "string" },
    "span_id": { "type": "string" },
    "parent_span_id": { "type": "string" },
    "session_id": { "type": "string" },
    "task_id": { "type": "string" },
    "agent_run_id": { "type": "string" },
    "agent_step_id": { "type": "string" },
    "invocation_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "agent_instance_id": { "type": "string" },
    "agent_type": { "$ref": "#/$defs/agent_type" },
    "parent_agent_id": { "type": "string" },
    "subagent_id": { "type": "string" },
    "shadow_candidate_id": { "type": "string" },
    "provider": { "type": "string" },
    "provider_api": { "type": "string" },
    "provider_request_id": { "type": "string" },
    "model": { "type": "string" },
    "model_version": { "type": "string" },
    "service_tier": { "type": "string" },
    "inference_region": { "type": "string" },
    "surface": { "type": "string" },
    "pep_type": { "type": "string" },
    "control_mode": { "type": "string" },
    "policy_ids": { "type": "array", "items": { "type": "string" } },
    "tokens": { "$ref": "#/$defs/canonical_token_usage" },
    "cost": { "$ref": "#/$defs/canonical_cost_breakdown" },
    "tool_id": { "type": "string" },
    "tool_name": { "type": "string" },
    "mcp_server_id": { "type": "string" },
    "resource_id": { "type": "string" },
    "resource_type": { "type": "string" },
    "latency_ms": { "type": "integer" },
    "status": { "type": "string" },
    "error_code": { "type": "string" },
    "provider_usage_raw": { "type": "object" },
    "metadata": { "type": "object" },
    "local_sequence": { "type": "integer" },
    "cloud_sync_status": { "type": "string", "enum": ["pending", "sent", "acked", "failed"] },
    "idempotency_key": { "type": "string" }
  },
  "$defs": {
    "ai_usage_event_kind": {
      "type": "string",
      "enum": [
        "agent_run_started",
        "agent_run_completed",
        "agent_step_started",
        "agent_step_completed",
        "model_call_started",
        "model_call_chunk",
        "model_call_completed",
        "tool_call_started",
        "tool_call_completed",
        "resource_access",
        "budget_preflight",
        "budget_alert",
        "budget_blocked",
        "usage_reconciled"
      ]
    },
    "agent_type": {
      "type": "string",
      "enum": [
        "local_agent",
        "browser_ai",
        "coding_agent",
        "claude_code",
        "codex_cli",
        "cursor",
        "mcp_client",
        "mcp_server_agent",
        "a2a_agent",
        "managed_agent",
        "gateway_agent",
        "shadow_ai",
        "unknown"
      ]
    },
    "usage_source": {
      "type": "string",
      "enum": [
        "provider_response",
        "provider_streaming_final",
        "provider_billing_export",
        "sdk_instrumentation",
        "proxy_observation",
        "browser_estimate",
        "local_tokenizer_estimate",
        "manual_import",
        "reconciled",
        "unknown"
      ]
    },
    "cost_source": {
      "type": "string",
      "enum": [
        "provider_reported",
        "price_catalog_exact",
        "price_catalog_tiered",
        "estimated_tokenizer",
        "billing_reconciled",
        "unknown"
      ]
    },
    "canonical_token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens",
        "cached_input_tokens",
        "cache_write_input_tokens",
        "reasoning_output_tokens",
        "tool_prompt_tokens",
        "tool_result_tokens",
        "image_input_tokens",
        "image_output_tokens",
        "audio_input_tokens",
        "audio_output_tokens",
        "video_input_tokens",
        "by_modality",
        "usage_details_ext",
        "estimated",
        "source"
      ],
      "properties": {
        "input_tokens": { "type": "integer" },
        "output_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "cached_input_tokens": { "type": "integer" },
        "cache_write_input_tokens": { "type": "integer" },
        "cache_write_input_tokens_5m": { "type": "integer" },
        "cache_write_input_tokens_1h": { "type": "integer" },
        "reasoning_output_tokens": { "type": "integer" },
        "reasoning_input_tokens": { "type": "integer" },
        "tool_prompt_tokens": { "type": "integer" },
        "tool_result_tokens": { "type": "integer" },
        "image_input_tokens": { "type": "integer" },
        "image_output_tokens": { "type": "integer" },
        "audio_input_tokens": { "type": "integer" },
        "audio_output_tokens": { "type": "integer" },
        "video_input_tokens": { "type": "integer" },
        "by_modality": { "type": "object", "additionalProperties": { "type": "integer" } },
        "usage_details_ext": { "type": "object", "additionalProperties": { "type": "integer" } },
        "estimated": { "type": "boolean" },
        "source": { "$ref": "#/$defs/usage_source" }
      }
    },
    "canonical_cost_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "input_cost",
        "output_cost",
        "cached_input_cost",
        "cache_write_input_cost",
        "reasoning_output_cost",
        "tool_cost",
        "image_cost",
        "audio_cost",
        "total_cost",
        "cost_source",
        "estimated",
        "cost_details_ext"
      ],
      "properties": {
        "currency": { "type": "string" },
        "input_cost": { "type": "number" },
        "output_cost": { "type": "number" },
        "cached_input_cost": { "type": "number" },
        "cache_write_input_cost": { "type": "number" },
        "reasoning_output_cost": { "type": "number" },
        "tool_cost": { "type": "number" },
        "image_cost": { "type": "number" },
        "audio_cost": { "type": "number" },
        "total_cost": { "type": "number" },
        "price_catalog_version": { "type": "string" },
        "pricing_tier_id": { "type": "string" },
        "cost_source": { "$ref": "#/$defs/cost_source" },
        "estimated": { "type": "boolean" },
        "cost_details_ext": { "type": "object", "additionalProperties": { "type": "number" } }
      }
    }
  }
}
