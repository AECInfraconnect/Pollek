{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollen.dev/schemas/ai-budget-event.v1.schema.json",
  "title": "AiBudgetEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "tenant_id",
    "scope_type",
    "scope_id",
    "event_kind",
    "occurred_at",
    "action"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "ai-budget-event.v1" },
    "event_id": { "type": "string" },
    "tenant_id": { "type": "string" },
    "budget_id": { "type": "string" },
    "scope_type": { "type": "string" },
    "scope_id": { "type": "string" },
    "event_kind": { "type": "string", "enum": ["preflight", "soft_exceeded", "hard_exceeded", "blocked", "approved"] },
    "occurred_at": { "type": "string", "format": "date-time" },
    "current_cost": { "type": "number" },
    "current_tokens": { "type": "integer" },
    "projected_cost": { "type": "number" },
    "projected_tokens": { "type": "integer" },
    "action": { "type": "string" },
    "related_usage_event_id": { "type": "string" },
    "data": { "type": "object" }
  }
}
