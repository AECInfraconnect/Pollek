<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="Pollek DEK" Language="1033" Version="1.0.0.0" Manufacturer="Pollek" UpgradeCode="a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of Pollek DEK is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="PollekDEK">
                    <!-- Standard Windows location for the dashboard assets, beside the
                         binaries. local-control-plane auto-discovers <exe_dir>\dashboard. -->
                    <Directory Id="DASHBOARDDIR" Name="dashboard" />
                </Directory>
            </Directory>
            <Directory Id="CommonAppDataFolder">
                <Directory Id="DATAFOLDER" Name="PollekDEK" />
            </Directory>
        </Directory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="DekCoreExe" Guid="*">
                <File Id="dek_core_exe" Source="target\release\dek-core.exe" KeyPath="yes" />
                <ServiceInstall Id="ServiceInstaller" Type="ownProcess" Name="PollekDEKCore" DisplayName="Pollek DEK Core Service" Description="Pollek Distributed Enforcement Kernel" Start="auto" Account="LocalSystem" ErrorControl="normal" />
                <ServiceControl Id="StartService" Stop="both" Remove="uninstall" Name="PollekDEKCore" Wait="yes" />
            </Component>
            <Component Id="DekMcpProxyExe" Guid="*">
                <File Id="dek_mcp_proxy_exe" Source="target\release\dek-mcp-proxy.exe" KeyPath="yes" />
            </Component>
            <Component Id="DekUpdaterExe" Guid="*">
                <File Id="dek_updater_exe" Source="target\release\dek-updater.exe" KeyPath="yes" />
            </Component>
            <Component Id="LocalControlPlaneExe" Guid="*">
                <File Id="local_control_plane_exe" Source="target\release\local-control-plane.exe" KeyPath="yes" />
                <ServiceInstall Id="DashboardServiceInstaller" Type="ownProcess" Name="PollekDEKDashboard" DisplayName="Pollek DEK Local Admin Dashboard" Description="Serves the Pollek DEK local admin dashboard and Local Control Plane API on 127.0.0.1:43891" Start="auto" Account="LocalSystem" ErrorControl="normal" />
                <ServiceControl Id="StartDashboardService" Stop="both" Remove="uninstall" Name="PollekDEKDashboard" Wait="yes" />
            </Component>
        </ComponentGroup>

        <Feature Id="ProductFeature" Title="Pollek DEK Core" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <!-- Dashboard assets, harvested from apps/local-admin-dashboard/dist by
                 heat.exe at build time into target\wix\dashboard.wxs. -->
            <ComponentGroupRef Id="HarvestedDashboard" />
        </Feature>
    </Product>
</Wix>
