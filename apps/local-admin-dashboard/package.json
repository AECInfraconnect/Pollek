{
  "name": "local-admin-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "e2e": "node e2e/run-playwright.mjs",
    "storybook": "node scripts/run-storybook.mjs dev -p 6006 --no-open",
    "build-storybook": "node scripts/run-storybook.mjs build",
    "a11y": "node e2e/run-playwright.mjs a11y-gate.spec.ts",
    "i18n:check": "node scripts/check-i18n-coverage.mjs",
    "visual:qa": "node e2e/run-playwright.mjs visual-smoke.spec.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "axe-core": "^4.12.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "storybook": "^10.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  }
}
