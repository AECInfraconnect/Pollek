{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionResult",
  "type": "object",
  "required": [
    "combined_reason",
    "evaluator_results",
    "final_decision",
    "obligations",
    "request_id",
    "schema_version"
  ],
  "properties": {
    "combined_reason": {
      "type": "string"
    },
    "evaluator_results": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EvaluatorResult"
      }
    },
    "final_decision": {
      "type": "string"
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "request_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    }
  },
  "definitions": {
    "EvaluatorResult": {
      "type": "object",
      "required": [
        "decision",
        "evaluator",
        "latency_ms",
        "reason"
      ],
      "properties": {
        "decision": {
          "type": "string"
        },
        "evaluator": {
          "type": "string"
        },
        "latency_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}