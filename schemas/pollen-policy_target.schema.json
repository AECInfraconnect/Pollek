{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolicyTarget",
  "type": "object",
  "required": [
    "evaluators",
    "match",
    "obligations",
    "schema_version",
    "target_id",
    "tenant_id"
  ],
  "properties": {
    "evaluators": {
      "$ref": "#/definitions/Evaluators"
    },
    "match": {
      "$ref": "#/definitions/MatchCriteria"
    },
    "obligations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "string"
    },
    "target_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    }
  },
  "definitions": {
    "ActionMatch": {
      "type": "object",
      "properties": {
        "in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "AgentMatch": {
      "type": "object",
      "properties": {
        "agent_types": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "risk_max": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ConditionalEvaluator": {
      "type": "object",
      "required": [
        "evaluator",
        "when"
      ],
      "properties": {
        "evaluator": {
          "type": "string"
        },
        "when": {
          "type": "string"
        }
      }
    },
    "Evaluators": {
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "conditional": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ConditionalEvaluator"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "MatchCriteria": {
      "type": "object",
      "properties": {
        "action": {
          "anyOf": [
            {
              "$ref": "#/definitions/ActionMatch"
            },
            {
              "type": "null"
            }
          ]
        },
        "agent": {
          "anyOf": [
            {
              "$ref": "#/definitions/AgentMatch"
            },
            {
              "type": "null"
            }
          ]
        },
        "network": {
          "anyOf": [
            {
              "$ref": "#/definitions/NetworkMatch"
            },
            {
              "type": "null"
            }
          ]
        },
        "principal": {
          "anyOf": [
            {
              "$ref": "#/definitions/PrincipalMatch"
            },
            {
              "type": "null"
            }
          ]
        },
        "resource": {
          "anyOf": [
            {
              "$ref": "#/definitions/ResourceMatch"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "NetworkMatch": {
      "type": "object",
      "properties": {
        "dest_cidr_in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "dest_port_in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "integer",
            "format": "uint16",
            "minimum": 0.0
          }
        }
      }
    },
    "PrincipalMatch": {
      "type": "object",
      "properties": {
        "attributes": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "entity_types": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ResourceMatch": {
      "type": "object",
      "properties": {
        "classification_in": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "data_categories_any": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}