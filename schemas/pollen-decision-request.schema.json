{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecisionRequest",
  "type": "object",
  "required": [
    "action",
    "agent",
    "context",
    "device_id",
    "input_hash",
    "pep",
    "principal",
    "request_id",
    "resource",
    "schema_version",
    "spiffe_id",
    "tenant_id",
    "trace_id"
  ],
  "properties": {
    "action": {
      "type": "string"
    },
    "agent": {
      "$ref": "#/definitions/AgentContext"
    },
    "context": {
      "$ref": "#/definitions/RequestContext"
    },
    "device_id": {
      "type": "string"
    },
    "input_hash": {
      "type": "string"
    },
    "pep": {
      "$ref": "#/definitions/PepInfo"
    },
    "principal": {
      "$ref": "#/definitions/PrincipalContext"
    },
    "request_id": {
      "type": "string"
    },
    "resource": {
      "$ref": "#/definitions/ResourceContext"
    },
    "schema_version": {
      "type": "string"
    },
    "spiffe_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    }
  },
  "definitions": {
    "AgentContext": {
      "type": "object",
      "required": [
        "agent_id",
        "runtime",
        "type"
      ],
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "runtime": {
          "type": "object",
          "additionalProperties": true
        },
        "type": {
          "type": "string"
        }
      }
    },
    "PepInfo": {
      "type": "object",
      "required": [
        "mode",
        "version"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "PrincipalContext": {
      "type": "object",
      "required": [
        "attributes",
        "entity_id",
        "identity_assurance",
        "type"
      ],
      "properties": {
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "entity_id": {
          "type": "string"
        },
        "identity_assurance": {
          "type": "object",
          "additionalProperties": true
        },
        "type": {
          "type": "string"
        }
      }
    },
    "RequestContext": {
      "type": "object",
      "required": [
        "mcp",
        "network",
        "risk",
        "runtime",
        "session"
      ],
      "properties": {
        "mcp": {
          "type": "object",
          "additionalProperties": true
        },
        "network": {
          "type": "object",
          "additionalProperties": true
        },
        "risk": {
          "type": "object",
          "additionalProperties": true
        },
        "runtime": {
          "type": "object",
          "additionalProperties": true
        },
        "session": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ResourceContext": {
      "type": "object",
      "required": [
        "classification",
        "resource_id",
        "type",
        "uri"
      ],
      "properties": {
        "classification": {
          "type": "string"
        },
        "resource_id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      }
    }
  }
}