        "device_id": {
          "type": "string"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "ebpf_guardrail"
          ]
        },
        "fqdn": {
          "type": "string"
        },
        "map_name": {
          "type": "string"
        },
        "pid": {
