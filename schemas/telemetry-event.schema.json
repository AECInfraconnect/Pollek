        },
        "device_id": {
          "type": "string"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "security"
          ]
        },
        "schema_version": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "tenant_id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "device_id",
        "event_type",
        "metrics",
