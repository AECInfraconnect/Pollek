{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error Envelope",
  "type": "object",
  "properties": {
    "error_id": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "safe_message": {
      "type": "string"
    },
    "retry_class": {
      "type": "string",
      "enum": ["no_retry", "retry_immediate", "retry_with_backoff", "retry_after_reauth", "retry_after_admin_action", "fatal_requires_reinstall"]
    },
    "safety_action": {
      "type": "string",
      "enum": ["deny_request", "keep_last_known_good", "enter_observe_only", "enter_degraded_mode", "stop_service", "quarantine_artifact"]
    },
    "tenant_id": {
      "type": "string"
    },
    "device_id": {
      "type": "string"
    },
    "bundle_version": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "remediation": {
      "type": "string"
    }
  },
  "required": ["error_id", "domain", "code", "message", "safe_message", "retry_class", "safety_action", "timestamp"]
}
