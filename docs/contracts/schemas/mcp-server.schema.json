{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpServer",
  "type": "object",
  "required": [
    "endpoint",
    "name",
    "schema_version",
    "server_id",
    "status",
    "tenant_id",
    "tools",
    "transport"
  ],
  "properties": {
    "endpoint": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "server_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/McpTool"
      }
    },
    "transport": {
      "type": "string"
    }
  },
  "definitions": {
    "McpTool": {
      "type": "object",
      "required": [
        "category",
        "input_schema_hash",
        "name",
        "output_schema_hash",
        "risk_level",
        "tool_id"
      ],
      "properties": {
        "category": {
          "type": "string"
        },
        "input_schema_hash": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "output_schema_hash": {
          "type": "string"
        },
        "risk_level": {
          "type": "string"
        },
        "tool_id": {
          "type": "string"
        }
      }
    }
  }
}