{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tenant",
  "type": "object",
  "required": [
    "created_at",
    "data_region",
    "default_fail_mode",
    "display_name",
    "policy_mode",
    "schema_version",
    "tenant_id",
    "tenant_type",
    "trust_domain",
    "trust_domain_strategy"
  ],
  "properties": {
    "created_at": {
      "type": "string"
    },
    "data_region": {
      "type": "string"
    },
    "default_fail_mode": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "policy_mode": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "tenant_type": {
      "type": "string"
    },
    "trust_domain": {
      "type": "string"
    },
    "trust_domain_strategy": {
      "$ref": "#/definitions/TrustDomainStrategy"
    }
  },
  "definitions": {
    "TrustDomainStrategy": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "shared",
            "dedicated",
            "federated",
            "customer_managed"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}