{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AiAgent",
  "type": "object",
  "required": [
    "agent_id",
    "agent_type",
    "allowed_mcp_servers",
    "capabilities",
    "name",
    "owner_principal_id",
    "risk_level",
    "runtime",
    "schema_version",
    "status",
    "tags",
    "tenant_id"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "agent_type": {
      "type": "string"
    },
    "allowed_mcp_servers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name": {
      "type": "string"
    },
    "owner_principal_id": {
      "type": "string"
    },
    "risk_level": {
      "type": "string"
    },
    "runtime": {
      "$ref": "#/definitions/Runtime"
    },
    "schema_version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tenant_id": {
      "type": "string"
    }
  },
  "definitions": {
    "Runtime": {
      "type": "object",
      "required": [
        "runtime_name",
        "vendor",
        "version"
      ],
      "properties": {
        "runtime_name": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    }
  }
}