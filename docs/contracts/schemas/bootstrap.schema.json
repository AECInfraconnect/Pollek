{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bootstrap Config",
  "type": "object",
  "properties": {
    "tenant_id": { "type": "string" },
    "device_id": { "type": "string" },
    "api_url": {
      "type": "string",
      "description": "Base URL of the Control Plane API"
    },
    "join_token": { "type": "string" }
  },
  "required": ["api_url"]
}
